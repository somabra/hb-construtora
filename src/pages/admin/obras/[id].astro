---
export const prerender = false;
import AdminLayout from '../../../layouts/AdminLayout.astro';
import ImageUploader from '../../../components/admin/ImageUploader.tsx';
import { resolveImg } from '../../../lib/site-content';

const supabase = Astro.locals.supabase!;
const user = Astro.locals.user!;
const { id } = Astro.params;

const { data: obra } = await supabase.from('obras').select('*').eq('id', id).maybeSingle();
if (!obra) return Astro.redirect('/admin/obras');

const { data: fotos } = await supabase
  .from('obra_fotos')
  .select('*')
  .eq('obra_id', id)
  .order('position', { ascending: true });

const STORAGE_URL = `${import.meta.env.PUBLIC_SUPABASE_URL}/storage/v1/object/public/site-media/`;
const saved = Astro.url.searchParams.get('saved');
---

<AdminLayout title={`Obra: ${obra.titulo}`} user={user}>

  <a href="/admin/obras" class="inline-flex items-center gap-1 text-brand-orange text-sm font-semibold mb-4 hover:underline">
    <span class="material-symbols-outlined text-[18px]">arrow_back</span>
    Voltar pra lista de obras
  </a>

  {saved && (
    <div class="bg-green-50 border border-green-200 text-success rounded-lg px-4 py-3 mb-6 text-sm">
      ✅ Salvo!
    </div>
  )}

  <!-- Metadados -->
  <form method="POST" action="/api/admin/obras" class="bg-white rounded-2xl border border-gray-200 p-4 sm:p-6 mb-6 space-y-4">
    <input type="hidden" name="_action" value="update" />
    <input type="hidden" name="id" value={obra.id} />

    <h3 class="font-bold text-primary text-lg">Informações da obra</h3>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <label class="block text-xs uppercase tracking-wider text-gray-500 mb-1.5">Título</label>
        <input name="titulo" type="text" required value={obra.titulo} class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-brand-orange" />
      </div>
      <div>
        <label class="block text-xs uppercase tracking-wider text-gray-500 mb-1.5">Local</label>
        <input name="local" type="text" value={obra.local ?? ''} class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-brand-orange" />
      </div>
    </div>

    <div>
      <label class="block text-xs uppercase tracking-wider text-gray-500 mb-1.5">Foto de capa</label>
      <ImageUploader name="cover_path" initial={obra.cover_path} folder="obras" storagePublicUrl={STORAGE_URL} client:load />
    </div>

    <label class="flex items-center gap-2 text-sm text-gray-600">
      <input type="checkbox" name="enabled" value="true" checked={obra.enabled} class="w-4 h-4" />
      Visível no site
    </label>

    <div class="text-right pt-2">
      <button type="submit" class="bg-orange-gradient text-white px-5 py-2 rounded-lg text-xs font-bold uppercase tracking-wider hover:brightness-110">
        Salvar alterações
      </button>
    </div>
  </form>

  <!-- Fotos -->
  <div class="bg-white rounded-2xl border border-gray-200 p-4 sm:p-6 mb-6">
    <h3 class="font-bold text-primary text-lg mb-4">Fotos da obra ({fotos?.length ?? 0})</h3>

    <form method="POST" action="/api/admin/obra-fotos" class="bg-gray-50 rounded-lg p-4 mb-6 space-y-4">
      <input type="hidden" name="_action" value="add" />
      <input type="hidden" name="obra_id" value={obra.id} />

      <p class="text-sm font-semibold text-gray-700">Adicionar fotos (até 4 por vez)</p>

      <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
        {[0, 1, 2, 3].map((i) => (
          <div class="space-y-2">
            <p class="text-xs text-gray-500 font-medium">Foto {i + 1}</p>
            <ImageUploader name={`path_${i}`} folder={`obras/${obra.id}`} storagePublicUrl={STORAGE_URL} client:load />
            <input name={`alt_${i}`} type="text" placeholder="Descrição (opcional)" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-xs focus:outline-none focus:border-brand-orange" />
          </div>
        ))}
      </div>

      <div class="text-right">
        <button type="submit" class="bg-primary text-white px-4 py-2 rounded-lg text-xs font-bold uppercase tracking-wider hover:brightness-125">
          Adicionar fotos
        </button>
      </div>
    </form>

    {fotos && fotos.length > 0 ? (
      <ul class="grid grid-cols-2 md:grid-cols-3 gap-3">
        {fotos.map((f, idx) => (
          <li class="relative group rounded-lg overflow-hidden bg-gray-100 aspect-[4/3]">
            <img src={resolveImg(f.path)} alt={f.alt ?? ''} class="w-full h-full object-cover" />
            <div class="absolute inset-x-0 bottom-0 flex items-end justify-between p-2 gap-2 bg-gradient-to-t from-black/70 to-transparent md:bg-none md:from-transparent md:group-hover:bg-gradient-to-t md:group-hover:from-black/60 md:opacity-100 transition-all">
              <div class="flex gap-1">
                <form method="POST" action="/api/admin/obra-fotos" class="leading-none">
                  <input type="hidden" name="_action" value="reorder" />
                  <input type="hidden" name="id" value={f.id} />
                  <input type="hidden" name="obra_id" value={obra.id} />
                  <input type="hidden" name="dir" value="up" />
                  <button type="submit" disabled={idx === 0} class="w-8 h-8 rounded bg-white/95 text-gray-700 disabled:opacity-25 flex items-center justify-center shadow-sm text-base" aria-label="Mover pra esquerda">←</button>
                </form>
                <form method="POST" action="/api/admin/obra-fotos" class="leading-none">
                  <input type="hidden" name="_action" value="reorder" />
                  <input type="hidden" name="id" value={f.id} />
                  <input type="hidden" name="obra_id" value={obra.id} />
                  <input type="hidden" name="dir" value="down" />
                  <button type="submit" disabled={idx === fotos.length - 1} class="w-8 h-8 rounded bg-white/95 text-gray-700 disabled:opacity-25 flex items-center justify-center shadow-sm text-base" aria-label="Mover pra direita">→</button>
                </form>
              </div>
              <form method="POST" action="/api/admin/obra-fotos" onsubmit="return confirm('Apagar esta foto?')">
                <input type="hidden" name="_action" value="delete" />
                <input type="hidden" name="id" value={f.id} />
                <input type="hidden" name="obra_id" value={obra.id} />
                <button type="submit" class="w-8 h-8 rounded bg-red-500 text-white flex items-center justify-center shadow-sm text-base" aria-label="Apagar foto">×</button>
              </form>
            </div>
          </li>
        ))}
      </ul>
    ) : (
      <p class="text-center text-gray-400 py-8 text-sm">Nenhuma foto ainda. Adicione a primeira acima ☝️</p>
    )}
  </div>

</AdminLayout>
