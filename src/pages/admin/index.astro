---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';

const supabase = Astro.locals.supabase!;
const user = Astro.locals.user!;

const [{ count: leadsCount }, { count: servicosCount }, { count: obrasCount }, { count: faqCount }] = await Promise.all([
  supabase.from('leads').select('*', { count: 'exact', head: true }),
  supabase.from('servicos').select('*', { count: 'exact', head: true }),
  supabase.from('obras').select('*', { count: 'exact', head: true }),
  supabase.from('faq_items').select('*', { count: 'exact', head: true }),
]);

const { data: ultimosLeads } = await supabase
  .from('leads')
  .select('nome, telefone, tipo, created_at')
  .order('created_at', { ascending: false })
  .limit(5);

const cards = [
  { label: 'Leads recebidos',     value: leadsCount    ?? 0, href: '/admin/leads',    icon: 'inbox',                color: 'bg-brand-orange' },
  { label: 'Serviços ativos',     value: servicosCount ?? 0, href: '/admin/servicos', icon: 'home_repair_service',  color: 'bg-primary-container' },
  { label: 'Obras na galeria',    value: obrasCount    ?? 0, href: '/admin/obras',    icon: 'photo_library',        color: 'bg-success' },
  { label: 'Perguntas no FAQ',    value: faqCount      ?? 0, href: '/admin/faq',      icon: 'help',                 color: 'bg-secondary-container' },
];
---

<AdminLayout title="Dashboard" user={user}>

  <p class="text-gray-600 mb-8">Olá! Aqui você gerencia tudo do site da HB Construtora.</p>

  <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-10">
    {cards.map(c => (
      <a href={c.href} class="bg-white rounded-2xl p-5 border border-gray-200 hover:shadow-lg hover:-translate-y-0.5 transition-all">
        <div class={`${c.color} text-white w-10 h-10 rounded-lg flex items-center justify-center mb-3`}>
          <span class="material-symbols-outlined text-[22px]">{c.icon}</span>
        </div>
        <p class="text-3xl font-bold text-primary">{c.value}</p>
        <p class="text-xs text-gray-500 mt-1">{c.label}</p>
      </a>
    ))}
  </div>

  <div class="bg-white rounded-2xl border border-gray-200 overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between">
      <h2 class="font-bold text-primary">Últimos leads</h2>
      <a href="/admin/leads" class="text-brand-orange text-xs font-bold uppercase tracking-wider hover:underline">Ver todos →</a>
    </div>
    {ultimosLeads && ultimosLeads.length > 0 ? (
      <ul class="divide-y divide-gray-100">
        {ultimosLeads.map(l => (
          <li class="px-6 py-3 flex items-center justify-between gap-4 hover:bg-gray-50">
            <div class="min-w-0">
              <p class="font-semibold text-gray-800 truncate">{l.nome}</p>
              <p class="text-xs text-gray-500 truncate">{l.telefone} · {l.tipo}</p>
            </div>
            <p class="text-xs text-gray-400 whitespace-nowrap">{new Date(l.created_at).toLocaleString('pt-BR')}</p>
          </li>
        ))}
      </ul>
    ) : (
      <p class="px-6 py-10 text-center text-gray-400 text-sm">Nenhum lead recebido ainda.</p>
    )}
  </div>

</AdminLayout>
