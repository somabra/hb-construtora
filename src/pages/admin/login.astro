---
export const prerender = false;
import '../../styles/global.css';
const next = Astro.url.searchParams.get('next') || '/admin';
const error = Astro.url.searchParams.get('error');
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex,nofollow" />
    <title>Admin · HB Construtora</title>
    <link rel="icon" type="image/png" href="/logo-hb.webp" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Work+Sans:wght@700;800&family=Public+Sans:wght@400;700&display=swap" rel="stylesheet" />
  </head>
  <body class="min-h-screen bg-primary text-white font-body flex items-center justify-center p-6">
    <div class="w-full max-w-md">
      <div class="text-center mb-8">
        <img src="/logo-hb-branco.webp" alt="HB Construtora" class="h-16 mx-auto mb-3" />
        <h1 class="font-headline font-bold text-xl tracking-wide">Painel Administrativo</h1>
      </div>

      <form method="POST" action="/api/auth/signin" class="bg-primary-container/80 backdrop-blur rounded-2xl p-8 border border-white/10 shadow-2xl space-y-4">
        <input type="hidden" name="next" value={next} />

        <div>
          <label for="email" class="block text-xs text-white/50 mb-1.5 uppercase tracking-wide">E-mail</label>
          <input
            id="email"
            name="email"
            type="email"
            required
            autocomplete="email"
            class="w-full bg-white/5 border border-white/15 text-white placeholder-white/25 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-brand-orange transition-colors"
          />
        </div>
        <div>
          <label for="password" class="block text-xs text-white/50 mb-1.5 uppercase tracking-wide">Senha</label>
          <input
            id="password"
            name="password"
            type="password"
            required
            autocomplete="current-password"
            class="w-full bg-white/5 border border-white/15 text-white placeholder-white/25 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-brand-orange transition-colors"
          />
        </div>

        {error && (
          <p class="text-error text-sm text-center bg-error/10 border border-error/20 rounded-lg py-2 px-3">
            {error === 'invalid' ? 'E-mail ou senha incorretos.' : 'Erro ao entrar. Tente novamente.'}
          </p>
        )}

        <button
          type="submit"
          class="w-full bg-orange-gradient text-white py-3.5 font-bold uppercase tracking-widest text-sm hover:brightness-110 transition-all rounded-lg mt-2"
        >
          Entrar
        </button>
      </form>

      <p class="text-center text-white/40 text-xs mt-6">
        Acesso restrito · HB Construtora
      </p>
    </div>
  </body>
</html>
