---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'HB Construtora | Compromisso em Cada Detalhe',
  description = 'Construção civil em Sinop-MT. Casas, kitnets, prédios e galpões. Acompanhamento pessoal do projeto à entrega da chave.',
} = Astro.props;
---

<!doctype html>
<html class="scroll-smooth" lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Work+Sans:wght@700;800&family=Public+Sans:wght@400;700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-surface text-on-surface font-body selection:bg-secondary-container selection:text-white">
    <slot />
  </body>
</html>
