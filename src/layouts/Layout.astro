---
import '../styles/global.css';
import { asset } from '../lib/site-content';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
}

const {
  title = 'HB Construtora | Construção Civil em Sinop-MT',
  description = 'Construção civil em Sinop-MT. Casas, kitnets, prédios e galpões com mão de obra e material inclusos. Acompanhamento pessoal do projeto à entrega da chave.',
  ogImage = '/logo-hb.webp',
  noindex = false,
} = Astro.props;

const siteUrl = 'https://hb-construtora.vercel.app';
const canonical = new URL(Astro.url.pathname, siteUrl).toString();
const ogImageUrl = new URL(ogImage, siteUrl).toString();

// Só a home tem o Hero — preload do poster do vídeo (elemento LCP) só faz sentido lá.
const isHome = Astro.url.pathname === '/';

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'GeneralContractor',
  name: 'HB Construtora',
  image: ogImageUrl,
  url: siteUrl,
  telephone: '+55-66-99675-2309',
  priceRange: '$$',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Rua dos Angicos, 1494',
    addressLocality: 'Sinop',
    addressRegion: 'MT',
    postalCode: '78550-000',
    addressCountry: 'BR',
  },
  areaServed: {
    '@type': 'City',
    name: 'Sinop',
  },
  sameAs: [
    'https://instagram.com/hbconstrutoramt',
    'https://wa.me/5566996752309',
  ],
  description,
};
---

<!doctype html>
<html class="scroll-smooth" lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <!-- Abre a conexão com a CDN cedo: imagens (poster do LCP, logo) saem dela -->
    <link rel="preconnect" href="https://somabrasupabase.b-cdn.net" />
    <link rel="dns-prefetch" href="https://somabrasupabase.b-cdn.net" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="HB Construtora" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content="pt_BR" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Theme -->
    <meta name="theme-color" content="#020037" />
    <link rel="icon" type="image/png" href="/logo-hb.webp" />

    <!-- Fonts self-hosted (definidas em global.css) — preload evita FOUT/CLS -->
    <link rel="preload" href="/fonts/work-sans-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/public-sans-latin.woff2" as="font" type="font/woff2" crossorigin />

    {isHome && (
      <!-- Poster do vídeo do Hero é o maior elemento acima da dobra (LCP) -->
      <link rel="preload" as="image" href={asset('/hero/hero-thumb.webp')} fetchpriority="high" />
    )}

    <!-- JSON-LD LocalBusiness -->
    <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />

    <!-- Hotjar Tracking Code for HB Construtora -->
    <script is:inline>
      (function(h,o,t,j,a,r){
        h.hj=h.hj||function(){(h.hj.q=h.hj.q||[]).push(arguments)};
        h._hjSettings={hjid:6722648,hjsv:6};
        a=o.getElementsByTagName('head')[0];
        r=o.createElement('script');r.async=1;
        r.src=t+h._hjSettings.hjid+j+h._hjSettings.hjsv;
        a.appendChild(r);
      })(window,document,'https://static.hotjar.com/c/hotjar-','.js?sv=');
    </script>
  </head>
  <body class="bg-surface text-on-surface font-body selection:bg-secondary-container selection:text-white">
    <slot />
    <!-- Vídeos de fundo decorativos só carregam no desktop. No mobile eles nem
         recebem src (autoplay ignora preload=none e baixaria ~1,4MB à toa). -->
    <script is:inline>
      if (window.matchMedia('(min-width: 768px)').matches) {
        document.querySelectorAll('video[data-bgvideo]').forEach(function (v) {
          v.src = v.getAttribute('data-bgvideo');
          var p = v.play();
          if (p && p.catch) p.catch(function () {});
        });
      }
    </script>
    <script>
      import '../scripts/highlight-brush.ts';
    </script>
  </body>
</html>
