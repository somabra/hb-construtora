---
import WhatsappIcon from './WhatsappIcon.astro';
import { getSetting } from '../lib/site-content';
import { resolveImg, asset } from '../lib/site-content';
import { sanitizeRichText } from '../lib/sanitize';

interface HeroData { eyebrow: string; titulo_html: string; paragrafo: string; video_url: string; cta_text: string; }
interface WaData   { numero: string; mensagem_default: string; }

const hero = (await getSetting<HeroData>('hero')) ?? { eyebrow: '', titulo_html: '', paragrafo: '', video_url: '', cta_text: 'Falar conosco' };
const wa   = (await getSetting<WaData>('whatsapp')) ?? { numero: '5566996752309', mensagem_default: 'Olá!' };

const waHref = `https://wa.me/${wa.numero}?text=${encodeURIComponent(wa.mensagem_default)}`;

function ytEmbed(url: string): string | null {
  if (!url) return null;
  const m = url.match(/(?:youtube\.com\/(?:watch\?v=|embed\/)|youtu\.be\/)([\w-]{11})/);
  return m ? `https://www.youtube.com/embed/${m[1]}?rel=0&modestbranding=1` : null;
}

const raw = (hero.video_url ?? '').trim();
const videoEmbed = ytEmbed(raw);
const isMp4 = !!raw && !videoEmbed;
const mp4Src = isMp4 ? resolveImg(raw) : '';
---

<section id="home" class="relative overflow-hidden pt-28 pb-16 md:pt-36 md:pb-24">

  <div class="absolute inset-0 overflow-hidden">
    <video
      class="absolute inset-0 w-full h-full object-cover"
      src={asset('/contato/contato-bg.mp4')}
      poster={asset('/contato/contato-bg.webp')}
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
      aria-hidden="true"
    ></video>
    <div class="absolute inset-0 bg-primary/85"></div>
  </div>

  <div class="relative max-w-6xl mx-auto px-6 md:px-10">
    <div class="grid grid-cols-1 lg:grid-cols-[1.1fr_auto] gap-10 lg:gap-14 items-center">

      <div class="text-center lg:text-left">
        <span class="text-brand-orange font-bold tracking-[0.3em] uppercase text-xs mb-5 block">{hero.eyebrow}</span>

        <h1 class="font-headline text-4xl md:text-5xl lg:text-[3.4rem] font-bold text-white leading-[1.05] tracking-tight [text-wrap:balance]" set:html={sanitizeRichText(hero.titulo_html)}></h1>

        <p class="mt-6 text-white/75 leading-relaxed text-base md:text-lg max-w-xl mx-auto lg:mx-0 [text-wrap:pretty]">
          {hero.paragrafo}
        </p>
      </div>

      <div class="flex flex-col items-center gap-6 mx-auto lg:mx-0 w-full max-w-[320px] sm:max-w-[360px] lg:w-[360px]">
        <div id="hero-video-frame" class="relative w-full aspect-[9/16] rounded-3xl overflow-hidden border border-white/10 bg-primary-container/80 backdrop-blur-md shadow-2xl">
          {videoEmbed && (
            <iframe
              class="absolute inset-0 w-full h-full"
              src={videoEmbed}
              title="Vídeo institucional HB Construtora"
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              allowfullscreen
            ></iframe>
          )}
          {isMp4 && (
            <>
              <video
                id="hero-video"
                class="absolute inset-0 w-full h-full object-cover"
                src={mp4Src}
                poster={asset('/hero/hero-thumb.webp')}
                controls
                playsinline
                muted
                preload="metadata"
              ></video>
              <button
                id="hero-video-unmute"
                type="button"
                aria-label="Ativar som"
                class="absolute bottom-14 left-1/2 -translate-x-1/2 z-10 inline-flex items-center gap-2 bg-black/55 hover:bg-black/75 backdrop-blur-sm text-white px-4 py-2.5 rounded-full text-xs font-semibold uppercase tracking-wider shadow-lg transition-colors"
              >
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M16.5 12c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02zM3 9v6h4l5 5V4L7 9H3zm6-.17v6.34L7.83 14H5v-4h2.83L9 8.83z"/>
                </svg>
                Ativar som
              </button>
            </>
          )}
          {!videoEmbed && !isMp4 && (
            <div class="absolute inset-0 flex flex-col items-center justify-center text-white/40 px-6 text-center">
              <div class="w-20 h-20 rounded-full bg-white/5 border border-white/10 flex items-center justify-center mb-4">
                <svg class="w-8 h-8 ml-1" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M8 5v14l11-7z"/>
                </svg>
              </div>
              <span class="text-xs uppercase tracking-[0.3em]">Vídeo em breve</span>
            </div>
          )}
        </div>

        <a
          href={waHref}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-3 bg-whatsapp-gradient text-white px-10 py-4 text-sm font-bold uppercase tracking-wider whitespace-nowrap hover:brightness-110 transition-all rounded-lg shadow-lg shadow-green-900/30"
        >
          <WhatsappIcon class="w-5 h-5 flex-shrink-0" />
          {hero.cta_text}
        </a>
      </div>

    </div>
  </div>

  {isMp4 && (
    <div
      id="hero-video-modal"
      class="fixed inset-0 z-[80] hidden items-center justify-center px-5 py-8 opacity-0 transition-opacity duration-300"
      role="dialog"
      aria-modal="true"
      aria-labelledby="hero-video-modal-title"
    >
      <div class="absolute inset-0 bg-primary/70 backdrop-blur-md" data-modal-overlay></div>

      <div class="relative w-full max-w-md bg-primary-container/80 backdrop-blur-md rounded-2xl shadow-2xl px-7 py-8 md:px-9 md:py-10 text-center border border-white/10">
        <button
          type="button"
          data-modal-close
          aria-label="Fechar"
          class="absolute top-3 right-3 w-9 h-9 rounded-full text-white/60 hover:text-white hover:bg-white/10 flex items-center justify-center text-2xl leading-none transition-colors"
        >×</button>

        <div class="text-brand-orange text-xs md:text-sm font-bold uppercase tracking-[0.25em] mb-3">
          HB Construtora
        </div>

        <h3 id="hero-video-modal-title" class="font-headline text-3xl md:text-4xl font-bold text-white leading-tight">
          Pronto para dar o próximo passo na sua obra?
        </h3>

        <p class="mt-4 text-white/70 text-sm leading-relaxed">
          Fale direto com o Hemerson e tire suas dúvidas. Atendimento personalizado pra cada projeto.
        </p>

        <a
          href={waHref}
          target="_blank"
          rel="noopener"
          class="hero-video-cta mt-7 inline-flex items-center gap-3 bg-whatsapp-gradient text-white px-8 py-4 text-sm md:text-base font-bold uppercase tracking-wider hover:brightness-110 transition-all rounded-xl shadow-lg shadow-green-900/30"
        >
          <WhatsappIcon class="w-5 h-5 flex-shrink-0" />
          Falar com o Hemerson
        </a>
      </div>
    </div>
  )}

</section>

{isMp4 && (
  <script is:inline>
    (function () {
      var video = document.getElementById('hero-video');
      var modal = document.getElementById('hero-video-modal');
      var unmuteBtn = document.getElementById('hero-video-unmute');
      if (!video || !modal) return;

      function openModal() {
        modal.classList.remove('hidden');
        modal.classList.add('flex');
        document.body.style.overflow = 'hidden';
        requestAnimationFrame(function () {
          modal.classList.remove('opacity-0');
        });
      }
      function closeModal() {
        modal.classList.add('opacity-0');
        setTimeout(function () {
          modal.classList.add('hidden');
          modal.classList.remove('flex');
          document.body.style.overflow = '';
        }, 280);
      }

      video.addEventListener('ended', function () {
        setTimeout(openModal, 700);
      });

      modal.querySelectorAll('[data-modal-close], [data-modal-overlay]').forEach(function (el) {
        el.addEventListener('click', closeModal);
      });
      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && !modal.classList.contains('hidden')) closeModal();
      });

      // Autoplay roda UMA vez por carregamento. Se o user subir de novo, não dispara.
      // Mobile: precisa do user ter rolado + vídeo 95% visível.
      // Desktop: dispara quando o vídeo entra no viewport (já aparece junto do texto).
      var isDesktop = window.matchMedia('(min-width: 1024px)').matches;
      var hasAutoPlayed = false;

      function tryAutoPlay() {
        if (hasAutoPlayed) return;
        hasAutoPlayed = true;
        var p = video.play();
        if (p && p.catch) p.catch(function () { /* autoplay bloqueado */ });
      }

      if ('IntersectionObserver' in window) {
        var hasInteracted = isDesktop;
        if (!isDesktop) {
          function markInteraction() { hasInteracted = true; }
          // Toque direto na tela — sinal confiável, não dispara em scroll do browser ou address bar
          window.addEventListener('touchstart',  markInteraction, { once: true, passive: true });
          window.addEventListener('pointerdown', markInteraction, { once: true, passive: true });
        }

        var minRatio = isDesktop ? 0.5 : 0.95;
        var io = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            if (!hasAutoPlayed && hasInteracted && entry.isIntersecting && entry.intersectionRatio >= minRatio) {
              tryAutoPlay();
            } else if (!entry.isIntersecting && !video.paused && !video.ended) {
              video.pause();
            }
          });
        }, { threshold: [0, 0.5, 0.9, 0.95, 1] });
        io.observe(video);
      } else if (isDesktop) {
        tryAutoPlay();
      }

      // Botão "Ativar som"
      if (unmuteBtn) {
        function syncUnmuteVisibility() {
          if (video.muted || video.volume === 0) {
            unmuteBtn.classList.remove('hidden');
          } else {
            unmuteBtn.classList.add('hidden');
          }
        }
        unmuteBtn.addEventListener('click', function () {
          video.muted = false;
          if (video.volume === 0) video.volume = 1;
          // Reinicia do começo pra pessoa ouvir o áudio + ver o vídeo desde o início
          try { video.currentTime = 0; } catch (e) {}
          var p = video.play();
          if (p && p.catch) p.catch(function () {});
          syncUnmuteVisibility();
        });
        video.addEventListener('volumechange', syncUnmuteVisibility);
        syncUnmuteVisibility();
      }
    })();
  </script>
)}

<style>
  .hero-video-cta {
    animation: hero-cta-pulse 1.6s ease-in-out infinite;
  }
  @keyframes hero-cta-pulse {
    0%, 100% { transform: scale(1);    box-shadow: 0 10px 25px -5px rgba(20,83,45,0.35); }
    50%      { transform: scale(1.04); box-shadow: 0 14px 32px -4px rgba(20,83,45,0.55); }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-video-cta { animation: none; }
  }

  /* Em fullscreen, troca object-cover por contain para manter o formato vertical
     sem cortar topo/bottom. Fundo preto preenche as laterais (estilo YouTube retrato). */
  #hero-video:fullscreen,
  #hero-video:-webkit-full-screen {
    object-fit: contain !important;
    width: 100% !important;
    height: 100% !important;
    background: #000;
  }
</style>
