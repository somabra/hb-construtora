---
import { getServicos, resolveImg, asset } from '../lib/site-content';
const servicos = await getServicos();
const servicosClient = servicos.map(s => ({
  alt: s.titulo,
  title: s.titulo,
  desc: s.descricao,
  longDesc: s.longa_descricao ?? '',
  formValue: s.form_value ?? '',
  ctaText: s.cta_text ?? 'Quero saber mais',
  gallery: [resolveImg(s.imagem_path)],
}));
---

<section id="servicos" class="relative py-24 bg-primary text-white overflow-hidden rounded-t-[1.5rem] md:rounded-t-[2rem] -mt-8 md:-mt-10">

  <div class="absolute inset-0 pointer-events-none">
    <img src={asset('/servicos/bg.webp')} alt="" class="w-full h-full object-cover opacity-25" />
    <div class="absolute inset-0 bg-primary/70"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-8">

    <div class="mb-16">
      <span class="text-secondary font-bold tracking-[0.3em] uppercase text-xs mb-4 block">O que fazemos</span>
      <h2 class="font-headline text-4xl md:text-5xl font-bold tracking-tight">Soluções completas de construção</h2>
    </div>

    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
      {servicosClient.map((s, i) => (
        <button
          type="button"
          data-servico-trigger
          data-index={i}
          class="servico-card group relative overflow-hidden aspect-[3/4] border border-white/10 hover:border-secondary/50 transition-all duration-300 hover:scale-[1.03] active:scale-[0.98] cursor-pointer text-left"
        >
          <img
            src={s.gallery[0]}
            alt={s.alt}
            loading="lazy"
            width="600"
            height="800"
            class="absolute inset-0 w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-700"
          />
          <div class="absolute inset-0 bg-primary/60 group-hover:bg-primary/20 transition-all"></div>
          <div class="absolute bottom-0 left-0 p-4 md:p-8">
            <h3 class="font-headline text-lg md:text-2xl font-bold mb-1 md:mb-2">{s.title}</h3>
            <p class="text-white/60 text-xs md:text-sm transform translate-y-8 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all">
              {s.desc}
            </p>
          </div>
          <div class="absolute top-3 right-3 md:top-4 md:right-4 w-8 h-8 md:w-10 md:h-10 rounded-full bg-secondary/90 backdrop-blur-sm flex items-center justify-center opacity-80 group-hover:opacity-100 group-hover:scale-110 transition-all">
            <svg class="w-4 h-4 md:w-5 md:h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
            </svg>
          </div>
        </button>
      ))}
    </div>

    <div class="text-center mt-12">
      <a
        href="#contato"
        class="inline-block bg-orange-gradient text-white px-10 py-4 font-bold uppercase tracking-widest text-sm hover:brightness-110 transition-all"
      >
        Solicitar Orçamento
      </a>
    </div>

  </div>
</section>

<!-- Modal Serviço -->
<div id="servico-modal" class="hidden fixed inset-0 z-[100] items-center justify-center p-4 bg-black/60 backdrop-blur-sm">
  <div id="modal-content" class="relative max-w-2xl w-full bg-primary-container/85 backdrop-blur-xl border border-white/15 rounded-2xl overflow-hidden shadow-2xl max-h-[90vh] flex flex-col transition-all duration-300 scale-95 opacity-0">
    <button id="modal-close" type="button" class="absolute top-3 right-3 z-20 w-10 h-10 rounded-full bg-black/60 hover:bg-black/90 text-white flex items-center justify-center transition-colors" aria-label="Fechar">
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>

    <div class="relative flex-shrink-0 bg-black">
      <div class="aspect-video w-full overflow-hidden">
        <img id="modal-img" src="" alt="" class="w-full h-full object-cover transition-opacity duration-300" />
      </div>
    </div>

    <div class="p-6 md:p-10 overflow-y-auto text-center">
      <h3 id="modal-title" class="font-headline text-3xl md:text-4xl font-bold text-white mb-4"></h3>
      <p id="modal-desc" class="text-white/75 leading-relaxed text-base md:text-lg mb-8 text-left whitespace-pre-line"></p>
      <button
        type="button"
        id="modal-cta"
        class="inline-block bg-orange-gradient text-white px-8 py-4 font-bold uppercase tracking-widest text-sm hover:brightness-110 transition-all rounded-md"
      ></button>
    </div>
  </div>
</div>

<script type="application/json" id="servicos-data" set:html={JSON.stringify(servicosClient)}></script>

<script>
  type Servico = { alt: string; title: string; desc: string; longDesc: string; formValue: string; ctaText: string; gallery: string[] };
  const dataEl = document.getElementById('servicos-data') as HTMLElement;
  const servicosData: Servico[] = JSON.parse(dataEl.textContent || '[]');

  const modal       = document.getElementById('servico-modal') as HTMLElement;
  const modalContent= document.getElementById('modal-content') as HTMLElement;
  const modalImg    = document.getElementById('modal-img') as HTMLImageElement;
  const modalTitle  = document.getElementById('modal-title') as HTMLElement;
  const modalDesc   = document.getElementById('modal-desc') as HTMLElement;
  const modalCta    = document.getElementById('modal-cta') as HTMLButtonElement;
  const closeBtn    = document.getElementById('modal-close') as HTMLButtonElement;

  function openModal(index: number) {
    const s = servicosData[index];
    if (!s) return;
    modalImg.src = s.gallery[0] || '';
    modalImg.alt = s.alt;
    modalTitle.textContent = s.title;
    modalDesc.textContent = s.longDesc;
    modalCta.textContent = s.ctaText;
    modalCta.dataset.formValue = s.formValue;
    modal.classList.remove('hidden');
    modal.classList.add('flex');
    document.body.style.overflow = 'hidden';
    // Empurra um estado no histórico — botão "voltar" do celular fecha o modal em vez de sair do site
    history.pushState({ servicoModal: true }, '');
    requestAnimationFrame(() => {
      modalContent.classList.remove('scale-95', 'opacity-0');
      modalContent.classList.add('scale-100', 'opacity-100');
    });
  }

  // Apenas anima e esconde — NÃO mexe no history (popstate fica responsável por isso)
  function closeModal() {
    if (modal.classList.contains('hidden')) return;
    modalContent.classList.remove('scale-100', 'opacity-100');
    modalContent.classList.add('scale-95', 'opacity-0');
    setTimeout(() => {
      modal.classList.add('hidden');
      modal.classList.remove('flex');
      document.body.style.overflow = '';
    }, 200);
  }

  // Wrapper chamado pelos botões/teclas: usa history.back se o estado existe (dispara popstate → closeModal),
  // senão fecha direto. Evita duplicar entradas no histórico ou estados órfãos.
  function dismissModal() {
    if (history.state && (history.state as any).servicoModal) {
      history.back();
    } else {
      closeModal();
    }
  }

  window.addEventListener('popstate', () => {
    if (!modal.classList.contains('hidden')) closeModal();
  });

  document.querySelectorAll<HTMLButtonElement>('[data-servico-trigger]').forEach(btn => {
    btn.addEventListener('click', () => {
      const idx = parseInt(btn.dataset.index || '0', 10);
      openModal(idx);
    });
  });

  closeBtn.addEventListener('click', dismissModal);
  modal.addEventListener('click', (e) => {
    if (e.target === modal) dismissModal();
  });

  modalCta.addEventListener('click', () => {
    const formValue = modalCta.dataset.formValue;
    if (formValue) {
      const opt = document.querySelector<HTMLButtonElement>(`.opt-tipo[data-value="${formValue}"]`);
      opt?.click();
    }
    dismissModal();
    setTimeout(() => {
      const target = document.getElementById('contato');
      target?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }, 220);
  });

  document.addEventListener('keydown', (e) => {
    if (modal.classList.contains('hidden')) return;
    if (e.key === 'Escape') dismissModal();
  });
</script>
