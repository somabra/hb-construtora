---
const servicos = [
  {
    img: 'https://lh3.googleusercontent.com/aida-public/AB6AXuCxnNYR0rx4_GD_4NfAylmwuIjiEyNZaEjZAHM5517hT7clZycAkyvVwdu-YtG70aanNvY727CW9ZrPojMjO1CG5DiuS4dHEf2TJ2HI2c15UBUplA3NL92FUlbFetgKEPUWQUFHRvrLIgs8iNioAvNNKbJ5qATzkz-a0k8cZn2qDhVHOlfaImibFniiCWP_p701YoOIa7KX1OssmDzaRvWNUjBLQO-F-4LNCYOb4Wiv-ikmpeQbE80lgPGDrQi4rVIsE62w1cX1hVlm',
    alt: 'Casa residencial moderna',
    title: 'Residencial',
    desc: 'Casas de alto padrão feitas sob medida para sua família.',
  },
  {
    img: 'https://lh3.googleusercontent.com/aida-public/AB6AXuA4X6bCeACxz3rc0F1D3XB2BZwudAXbr8UfNh56eCklfncnNnx6TJBCbc05j4a5R5RaoGo8VxIy4xUiWWF6C4iAphMiNAQEIcbajFKFpN8VkoqAKi0QDh956xjGw3XcAS3Ku1d9Nj0traurrOk3V0LJh4AqSzPJvBgfj5Cpjo9S79WR633wGhou2iGU_7AENbY-c2kyhiFXlyaJ_rllfkSTqlBOtC1TsOVdirOBO1TVaid33CvmJc7zXctHVGkf32rf2xtgyeKFJzSx',
    alt: 'Prédio de kitnets',
    title: 'Kitnets',
    desc: 'Projetos rentáveis para investidores inteligentes.',
  },
  {
    img: 'https://lh3.googleusercontent.com/aida-public/AB6AXuATK4wNo97crwuEie0WUqSN_13Xm6wRwyQgzCK_C9R_Vg15Mj_OHVxffV9m6M6CgllIGVuHv2PgOImFzDY6--R5odjPCBnmWGfrwW_kP3wVzNn3hTu4sBQwcq4Wza7YfLambY-Mvxse_7rebICd-JdjiKAkF88XcScJYc5s-tNHD8kL90Zf0MkynwEN3sega4bXHfiLJneGYRWdz4xNYPflK2UtBARKFeGD1vjKzyby_EjBIbBF50c6pWDkWS1j3kRgIly_u96QyA6y',
    alt: 'Prédio comercial',
    title: 'Prédios Comerciais',
    desc: 'Estruturas robustas para negócios de sucesso.',
  },
  {
    img: 'https://placehold.co/600x800/1a1a4e/ffffff?text=Barracão',
    alt: 'Galpão industrial',
    title: 'Barracões',
    desc: 'Construções industriais otimizadas e duráveis.',
  },
];
---

<section id="servicos" class="relative py-24 text-white rounded-t-3xl overflow-hidden">

  <!-- Fundo com foto e parallax -->
  <div class="absolute inset-0">
    <img id="servicos-parallax" src="/servicos-bg.jpg" alt="" class="w-full object-cover absolute left-0 right-0" style="height: 130%; top: -15%;" />
    <div class="absolute inset-0 bg-[#020037]/80"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-8">
    <div class="grid md:grid-cols-2 gap-12 items-center">

      <!-- Esquerda: texto -->
      <div>
        <span class="text-secondary font-bold tracking-[0.3em] uppercase text-xs mb-4 block">O que fazemos</span>
        <h2 class="font-headline text-4xl md:text-5xl font-bold tracking-tight leading-tight mb-6">
          Soluções de Construção Inteligente
        </h2>
        <p class="text-white/70 leading-relaxed mb-10">
          Da base ao acabamento, entregamos obras com qualidade impecável e acompanhamento pessoal em cada etapa do projeto.
        </p>
        <!-- Botão só no desktop (esquerda) -->
        <a
          href="#contato"
          class="hidden md:inline-block bg-gradient-to-r from-[#f0884a] to-[#d94e18] text-white px-10 py-4 font-bold uppercase tracking-widest text-sm hover:brightness-110 transition-all"
        >
          Solicitar Orçamento
        </a>
      </div>

      <!-- Direita: 4 cards 2x2 -->
      <div class="grid grid-cols-2 gap-3">
        {servicos.map(s => (
          <div class="group relative overflow-hidden aspect-square border border-white/10 hover:border-secondary/60 transition-all duration-500 rounded-xl shadow-lg hover:shadow-secondary/20 hover:shadow-2xl hover:-translate-y-1">
            <img
              src={s.img}
              alt={s.alt}
              class="absolute inset-0 w-full h-full object-cover grayscale group-hover:grayscale-0 scale-100 group-hover:scale-110 transition-all duration-700"
            />
            <div class="absolute inset-0 bg-primary/60 group-hover:bg-primary/20 transition-all duration-500 rounded-xl"></div>
            <!-- Brilho no hover -->
            <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 rounded-xl"
                 style="background: linear-gradient(135deg, rgba(255,255,255,0.08) 0%, transparent 60%);"></div>
            <!-- Linha laranja no topo -->
            <div class="absolute top-0 left-0 right-0 h-0.5 bg-gradient-to-r from-[#f0884a] to-[#d94e18] scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-left"></div>
            <div class="absolute bottom-0 left-0 p-4">
              <h3 class="font-headline text-base md:text-lg font-bold mb-1">{s.title}</h3>
              <p class="text-white/60 text-xs transform translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-300">
                {s.desc}
              </p>
            </div>
          </div>
        ))}
      </div>

    </div>

    <!-- Botão só no mobile, centralizado, abaixo dos cards -->
    <div class="md:hidden text-center mt-8">
      <a
        href="#contato"
        class="inline-block bg-gradient-to-r from-[#f0884a] to-[#d94e18] text-white px-10 py-4 font-bold uppercase tracking-widest text-sm hover:brightness-110 transition-all"
      >
        Solicitar Orçamento
      </a>
    </div>

  </div>
</section>

<script>
  const img     = document.getElementById('servicos-parallax') as HTMLImageElement;
  const section = document.getElementById('servicos') as HTMLElement;
  window.addEventListener('scroll', () => {
    const rect   = section.getBoundingClientRect();
    const offset = (window.innerHeight - rect.top) * 0.15;
    img.style.transform = `translateY(${offset}px)`;
  }, { passive: true });
</script>
