---

<section id="servicos" class="py-24 bg-primary text-white">
  <div class="max-w-7xl mx-auto px-8">

    <div class="mb-16">
      <span class="text-secondary font-bold tracking-[0.3em] uppercase text-xs mb-4 block">O que fazemos</span>
      <h2 class="font-headline text-4xl md:text-5xl font-bold tracking-tight">Soluções de Construção Inteligente</h2>
    </div>

    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
      {servicos.map(s => (
        <div class="group relative overflow-hidden aspect-[3/4] border border-white/10 hover:border-secondary/50 transition-colors">
          <img
            src={s.img}
            alt={s.alt}
            class="absolute inset-0 w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-700"
          />
          <div class="absolute inset-0 bg-primary/60 group-hover:bg-primary/20 transition-all"></div>
          <div class="absolute bottom-0 left-0 p-4 md:p-8">
            <h3 class="font-headline text-lg md:text-2xl font-bold mb-1 md:mb-2">{s.title}</h3>
            <p class="text-white/60 text-xs md:text-sm transform translate-y-8 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all">
              {s.desc}
            </p>
          </div>
        </div>
      ))}
    </div>

    <div class="text-center mt-12">
      <a
        href="#contato"
        class="inline-block bg-gradient-to-r from-[#f0884a] to-[#d94e18] text-white px-10 py-4 font-bold uppercase tracking-widest text-sm hover:brightness-110 transition-all"
      >
        Solicitar Orçamento
      </a>
    </div>

  </div>
</section>
