---
import { getSetting } from '../lib/site-content';
const wa = (await getSetting<{ numero: string; mensagem_default: string }>('whatsapp')) ?? { numero: '5566996752309', mensagem_default: '' };
const ano = new Date().getFullYear();

const numeroFmt = (() => {
  const d = wa.numero.replace(/\D/g, '');
  if (d.length >= 12) {
    return `(${d.slice(2, 4)}) ${d.slice(4, 9)}-${d.slice(9)}`;
  }
  return wa.numero;
})();
const waHref = `https://wa.me/${wa.numero}`;
---

<footer class="bg-primary-deep text-white/60 py-20">
  <div class="max-w-7xl mx-auto px-8">

    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-16">
      <div>
        <h3 class="text-white text-2xl font-bold font-headline mb-6 tracking-tighter">HB Construtora</h3>
        <p class="text-sm leading-relaxed">
          Qualidade e confiança na construção civil do Norte de Mato Grosso.
          Compromisso com o seu sonho do projeto à entrega da chave.
        </p>
      </div>

      <div>
        <h4 class="text-white font-bold mb-6 uppercase text-sm tracking-widest">Contato</h4>
        <ul class="space-y-3 text-sm">
          <li>
            <a href={waHref} target="_blank" rel="noopener noreferrer" class="hover:text-secondary transition-colors">
              {numeroFmt}
            </a>
          </li>
          <li>Sinop, MT</li>
        </ul>
      </div>

      <div>
        <h4 class="text-white font-bold mb-6 uppercase text-sm tracking-widest">Siga-nos</h4>
        <div class="flex gap-6">
          <a
            href="https://instagram.com/hbconstrutoramt"
            target="_blank"
            rel="noopener noreferrer"
            class="opacity-80 hover:opacity-100 hover:text-secondary transition-all"
          >
            Instagram
          </a>
          <a
            href={waHref}
            target="_blank"
            rel="noopener noreferrer"
            class="opacity-80 hover:opacity-100 hover:text-secondary transition-all"
          >
            WhatsApp
          </a>
        </div>
      </div>
    </div>

    <div class="pt-8 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-4 text-xs">
      <p>© {ano} HB Construtora. Todos os direitos reservados. Sinop-MT.</p>
      <p>Criado por <span class="text-white font-bold">Somabra Marketing</span></p>
    </div>

  </div>
</footer>
