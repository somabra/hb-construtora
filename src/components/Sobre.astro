---
---

<section id="sobre" class="bg-surface rounded-t-3xl -mt-8 relative z-10" style="padding-top: 4rem; padding-bottom: 0; overflow: visible;">
  <div class="max-w-7xl mx-auto px-8">
    <div class="grid md:grid-cols-2 gap-16 items-end">

      <!-- Mobile: flex row texto + foto | Desktop: só texto -->
      <div class="md:pb-16 flex gap-4 md:block items-stretch">

        <!-- Texto -->
        <div class="flex-1 min-w-0">
          <span class="text-secondary font-bold tracking-[0.3em] uppercase text-xs mb-4 block">Sobre o Fundador</span>
          <h2 class="font-headline text-3xl md:text-4xl font-bold text-primary mb-4 md:mb-6 leading-tight">Hemerson Borges</h2>

          <div class="text-on-surface-variant leading-relaxed mb-3 md:mb-0 text-sm md:text-base">
            <p>Com anos de experiência no setor de construção civil em Mato Grosso, Hemerson Borges fundou a HB Construtora com a missão de transformar o cenário de obras em Sinop.</p>
          </div>

          <!-- Conteúdo expandível — oculto no mobile, visível no desktop -->
          <div id="sobre-extra" class="hidden md:block md:space-y-4 text-on-surface-variant leading-relaxed md:mb-8 text-sm md:text-base">
            <p class="mt-3 md:mt-0">Nossa filosofia é baseada na verdade e no acompanhamento minucioso, garantindo que cada cliente tenha a tranquilidade de ver seu sonho sendo erguido com qualidade.</p>
          </div>

          <!-- Botão Ler mais — só no mobile -->
          <button id="btn-ler-mais" class="md:hidden text-secondary font-bold text-xs uppercase tracking-widest mt-3 mb-4 flex items-center gap-1">
            Ler mais
            <svg id="icon-ler-mais" class="w-3 h-3 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>

          <a
            href="https://wa.me/5566996752309"
            target="_blank"
            rel="noopener noreferrer"
            class="hidden md:inline-block bg-primary text-white px-8 py-4 font-bold uppercase tracking-widest text-sm hover:bg-secondary transition-all"
          >
            Converse com o Hemerson
          </a>
        </div>

        <!-- Foto só no mobile -->
        <div class="md:hidden flex-shrink-0 w-1/2 relative z-10">
          <img
            src="/hemerson.png"
            alt="Hemerson Borges"
            class="w-full h-full object-contain object-bottom drop-shadow-xl"
          />
        </div>

      </div>

      <!-- Espaço reservado para a foto no desktop -->
      <div class="hidden md:block"></div>

    </div>
  </div>

  <!-- Foto desktop: cabeça ultrapassa a seção acima (top: -3rem) -->
  <div class="hidden md:block absolute right-0 bottom-0 z-30" style="width: 45%; max-width: 520px; top: -3rem; right: 22rem;">
    <img
      src="/hemerson.png"
      alt="Hemerson Borges — Fundador da HB Construtora"
      class="w-full h-full object-contain object-bottom drop-shadow-2xl"
    />
  </div>

</section>

<script>
  const btnLer  = document.getElementById('btn-ler-mais');
  const extra   = document.getElementById('sobre-extra');
  const iconLer = document.getElementById('icon-ler-mais');
  let expandido = false;
  btnLer?.addEventListener('click', () => {
    expandido = !expandido;
    extra?.classList.toggle('hidden', !expandido);
    if (iconLer) iconLer.style.transform = expandido ? 'rotate(180deg)' : '';
    const textNode = [...btnLer!.childNodes].find(n => n.nodeType === 3);
    if (textNode) textNode.textContent = expandido ? 'Ler menos ' : 'Ler mais ';
  });
</script>
