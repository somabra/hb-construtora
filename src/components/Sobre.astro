---
import { getSetting } from '../lib/site-content';
import WhatsappIcon from './WhatsappIcon.astro';

interface Stat { prefix: string; target: number; suffix: string; label: string; }
interface SobreData { eyebrow: string; titulo: string; paragrafos: string[]; stats: Stat[]; cta_paragrafo?: string; }
interface WaData   { numero: string; mensagem_default: string; }

const sobre = (await getSetting<SobreData>('sobre')) ?? {
  eyebrow: 'Quem somos',
  titulo: 'Sobre a HB',
  paragrafos: [],
  stats: [],
};

const wa = (await getSetting<WaData>('whatsapp')) ?? { numero: '5566996752309', mensagem_default: 'Olá Hemerson!' };
const waMsgSobre = 'Olá Hemerson! Vi seu site e gostaria de conversar sobre uma obra.';
const waHrefSobre = `https://wa.me/${wa.numero}?text=${encodeURIComponent(waMsgSobre)}`;
---

<section id="sobre" class="bg-surface rounded-t-3xl -mt-8 relative z-10 overflow-hidden" style="padding-top: 4rem; padding-bottom: 0;">

  <div class="max-w-7xl mx-auto px-6 md:px-8">
    <div class="relative grid grid-cols-1 lg:grid-cols-[1.2fr_1fr] gap-10 lg:gap-14">

      <div class="text-center lg:text-left lg:self-start">
        <span class="text-secondary font-bold tracking-[0.3em] uppercase text-xs mb-4 block">{sobre.eyebrow}</span>
        <h2 class="font-headline text-4xl md:text-6xl font-bold text-primary mb-6 leading-tight">{sobre.titulo}</h2>

        <img
          src="/sobre/hemerson-retrato.webp"
          alt="Hemerson Borges, fundador da HB Construtora"
          class="lg:hidden w-full h-auto block max-w-[200px] mx-auto select-none pointer-events-none [-webkit-user-drag:none]"
          loading="lazy"
          draggable="false"
          oncontextmenu="return false"
          width="900"
          height="1293"
        />

        <div class="lg:hidden border-t border-primary/10 mb-8 -mx-6 md:-mx-8" aria-hidden="true"></div>

        <div class="text-on-surface-variant leading-relaxed text-sm md:text-base space-y-4 max-w-2xl mx-auto lg:mx-0">
          {sobre.paragrafos.map(p => <p>{p}</p>)}
        </div>

        {sobre.cta_paragrafo && (
          <p class="mt-6 md:mt-8 font-headline text-xl md:text-2xl font-bold text-primary leading-snug max-w-2xl mx-auto lg:mx-0">
            {sobre.cta_paragrafo}
          </p>
        )}

        <!-- Botão WhatsApp — mobile (logo após o CTA) -->
        <div class="lg:hidden mt-6 flex justify-center">
          <a
            href={waHrefSobre}
            target="_blank"
            rel="noopener noreferrer"
            class="sobre-wa-cta inline-flex items-center gap-3 bg-whatsapp-gradient text-white px-7 py-4 text-sm font-bold uppercase tracking-wider hover:brightness-110 transition-all rounded-xl shadow-lg shadow-green-900/30"
          >
            <WhatsappIcon class="w-5 h-5 flex-shrink-0" />
            Falar com o Hemerson
          </a>
        </div>
      </div>

      <div class="hidden lg:block lg:self-end">
        <div class="relative w-full max-w-[300px] mx-auto">
          <img
            src="/sobre/hemerson-retrato.webp"
            alt="Hemerson Borges, fundador da HB Construtora"
            class="w-full h-auto block select-none pointer-events-none [-webkit-user-drag:none]"
            loading="lazy"
            draggable="false"
            oncontextmenu="return false"
            width="900"
            height="1293"
          />
          <!-- Botão WhatsApp — sobreposto na foto, altura da barriga -->
          <a
            href={waHrefSobre}
            target="_blank"
            rel="noopener noreferrer"
            class="sobre-wa-cta absolute left-1/2 -translate-x-1/2 bottom-[28%] inline-flex items-center gap-3 bg-whatsapp-gradient text-white px-6 py-3.5 text-sm font-bold uppercase tracking-wider hover:brightness-110 transition-all rounded-xl shadow-2xl shadow-green-900/40 whitespace-nowrap"
          >
            <WhatsappIcon class="w-5 h-5 flex-shrink-0" />
            Falar com o Hemerson
          </a>
        </div>
      </div>

      <!-- Seta curva: sai do final do CTA e aponta pra direita-baixo, em direção ao botão sobreposto -->
      <svg
        class="hidden lg:block absolute pointer-events-none text-secondary"
        style="left: 50%; bottom: 18%; width: 180px; height: 100px;"
        viewBox="0 0 200 110"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M 5 15 Q 70 5, 130 45 T 188 90" />
        <path d="M 172 92 L 188 90 L 184 105" />
      </svg>

    </div>
  </div>

  <div class="border-t border-primary/10 w-full mt-10 lg:mt-0" aria-hidden="true"></div>

  <div class="max-w-4xl mx-auto px-4 md:px-8">
    <div id="stats-sobre" class="pb-16 md:pb-20 pt-10 md:pt-12">
      <div class="grid grid-cols-4 gap-x-2 md:gap-x-6 gap-y-10">
        {sobre.stats.map(({ prefix, target, suffix, label }) => (
          <div class="text-center">
            <div class="font-headline font-light text-2xl md:text-4xl leading-none mb-2 md:mb-3 text-primary">
              <span>{prefix}</span><span
                class="stat-number"
                data-target={target}
                data-suffix={suffix}
              >0{suffix}</span>
            </div>
            <div class="text-[9px] md:text-[11px] uppercase tracking-wider md:tracking-[0.2em] text-on-surface-variant leading-tight">
              {label}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>

</section>

<script>
  const statsContainer = document.getElementById('stats-sobre');
  const statNumbers = document.querySelectorAll<HTMLElement>('.stat-number');

  function animateStat(el: HTMLElement) {
    const target = Number(el.dataset.target ?? 0);
    const suffix = el.dataset.suffix ?? '';
    const duration = 1400;
    const start = performance.now();

    function tick(now: number) {
      const progress = Math.min((now - start) / duration, 1);
      const eased = 1 - Math.pow(1 - progress, 3);
      const current = Math.round(eased * target);
      el.textContent = current + suffix;
      if (progress < 1) requestAnimationFrame(tick);
      else el.textContent = target + suffix;
    }
    requestAnimationFrame(tick);
  }

  if (statsContainer && 'IntersectionObserver' in window) {
    const io = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          statNumbers.forEach(animateStat);
          io.disconnect();
        }
      });
    }, { threshold: 0.3 });
    io.observe(statsContainer);
  } else {
    statNumbers.forEach(animateStat);
  }
</script>
