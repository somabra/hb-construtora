---
const obras = [
  {
    img: '/obra-01.jpg',
    alt: 'Casa Residencial — HB Construtora',
    title: 'Casa Residencial',
  },
  {
    img: '/obra-02.jpg',
    alt: 'Entrega do Projeto — HB Construtora',
    title: 'Entrega do Projeto',
  },
  {
    img: 'https://lh3.googleusercontent.com/aida-public/AB6AXuBm2j1tiBn7wnAFpEbuoKtV7xaY5UX-iXNQydqTHqJB7RD2qEHDZ7fFUJZB1U4FtDVC0zz6bpA40VjRXzaVyCymiB8W_porQWrHS5AYnQi6IfXGZL3HXCfvJTbKHD9ePQ4a41hQW68YGwjtP-7aWZ9hkjD8lRL97InKApdfKucf_JG-QZVEcX7h7vURKsPtyxjvEsrURVFsW1JTiosvBs6fQClve1eW5blzB2YpL-tf_P6uqIuXmZAMdT8FIuUXe66Fq-VMK_BT-96b',
    alt: 'Centro Comercial Prime',
    title: 'Centro Comercial Prime',
  },
];
---

<section id="galeria" class="py-24 bg-white overflow-hidden">
  <div class="max-w-7xl mx-auto px-8">

    <div class="flex flex-col md:flex-row justify-between items-end mb-12 gap-8">
      <div>
        <span class="text-secondary font-bold tracking-[0.3em] uppercase text-xs mb-4 block">Portfólio</span>
        <h2 class="font-headline text-4xl md:text-5xl font-bold text-primary">Obras Entregues</h2>
      </div>
      <div class="flex gap-3">
        <button id="prev-btn" class="w-11 h-11 rounded-full border border-primary/20 flex items-center justify-center hover:bg-primary hover:text-white transition-all" aria-label="Anterior">
          <span class="material-symbols-outlined">chevron_left</span>
        </button>
        <button id="next-btn" class="w-11 h-11 rounded-full border border-primary/20 flex items-center justify-center hover:bg-primary hover:text-white transition-all" aria-label="Próximo">
          <span class="material-symbols-outlined">chevron_right</span>
        </button>
      </div>
    </div>

    <!-- Carrossel -->
    <div class="overflow-hidden">
      <div id="gallery-track" class="flex gap-6 transition-transform duration-500 ease-in-out">
        {obras.map(obra => (
          <div class="shrink-0 w-full md:w-[calc(50%-12px)] lg:w-[calc(33.33%-16px)]">
            <div class="rounded-2xl overflow-hidden aspect-[4/3] w-full">
              <img
                src={obra.img}
                alt={obra.alt}
                class="w-full h-full object-cover hover:scale-105 transition-transform duration-700"
              />
            </div>
            <h4 class="font-headline font-bold text-primary mt-4">{obra.title}</h4>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>

<script>
  const track   = document.getElementById('gallery-track')!;
  const prevBtn = document.getElementById('prev-btn')!;
  const nextBtn = document.getElementById('next-btn')!;
  let current = 0;

  function getVisible(): number {
    if (window.innerWidth >= 1024) return 3;
    if (window.innerWidth >= 768) return 2;
    return 1;
  }

  function updateGallery(): void {
    const item = track.children[0] as HTMLElement;
    const gap = 24;
    const itemWidth = item.offsetWidth + gap;
    const maxSlide = track.children.length - getVisible();
    current = Math.max(0, Math.min(current, maxSlide));
    track.style.transform = `translateX(-${current * itemWidth}px)`;
  }

  nextBtn.addEventListener('click', () => { current++; updateGallery(); });
  prevBtn.addEventListener('click', () => { current--; updateGallery(); });
  window.addEventListener('resize', updateGallery);
</script>
