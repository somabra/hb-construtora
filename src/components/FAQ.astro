---
import { getFAQ, getSetting } from '../lib/site-content';
import WhatsappIcon from './WhatsappIcon.astro';

const faqs = await getFAQ();

interface WaData { numero: string; mensagem_default: string; }
const wa = (await getSetting<WaData>('whatsapp')) ?? { numero: '5566996752309', mensagem_default: 'Olá Hemerson!' };

// Separa o texto da resposta de uma marcação opcional {cta-whatsapp:Texto do botão}.
// Permite editar respostas no admin com a frase de CTA sem mexer em código.
function splitAnswer(resposta: string): { text: string; ctaText: string | null } {
  const match = resposta.match(/\{cta-whatsapp:([^}]+)\}/);
  if (!match) return { text: resposta, ctaText: null };
  return {
    text: resposta.replace(match[0], '').trim(),
    ctaText: match[1].trim(),
  };
}

function waHrefFor(text: string): string {
  return `https://wa.me/${wa.numero}?text=${encodeURIComponent(text)}`;
}

const faqSchema = faqs.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({
    '@type': 'Question',
    name: f.pergunta,
    acceptedAnswer: {
      '@type': 'Answer',
      text: f.resposta,
    },
  })),
} : null;
---

{faqSchema && (
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
)}

<section id="faq" class="py-20 bg-gray-50">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="text-center mb-12">
      <p class="text-sm font-semibold tracking-widest uppercase text-brand-orange mb-2">Dúvidas Frequentes</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-primary-container">Perguntas Frequentes</h2>
      <div class="mt-4 mx-auto w-12 h-1 bg-brand-orange rounded"></div>
    </div>

    <div class="space-y-3" id="faq-list">
      {faqs.map((item) => {
        const { text, ctaText } = splitAnswer(item.resposta);
        const waMsg = ctaText ? `Olá Hemerson! ${ctaText}` : wa.mensagem_default;
        return (
          <div class="faq-item bg-white rounded-xl border border-gray-200 overflow-hidden shadow-sm">
            <button
              class="faq-btn w-full text-left px-6 py-5 flex justify-between items-center gap-4 hover:bg-gray-50 transition-colors"
              aria-expanded="false"
            >
              <span class="font-semibold text-primary-container text-base leading-snug">{item.pergunta}</span>
              <span class="faq-icon text-brand-orange text-xl flex-shrink-0 transition-transform duration-300">▾</span>
            </button>
            <div class="faq-answer hidden px-6 pb-5">
              <p class="text-gray-600 leading-relaxed text-sm whitespace-pre-line">{text}</p>
              {ctaText && (
                <a
                  href={waHrefFor(waMsg)}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="mt-4 inline-flex items-center gap-2.5 text-primary-container font-semibold text-sm border-b-2 border-brand-orange pb-1 hover:text-brand-orange transition-colors group"
                >
                  <span>{ctaText}</span>
                  <span class="inline-flex items-center justify-center w-7 h-7 rounded-full bg-whatsapp-gradient text-white shadow-md group-hover:scale-110 transition-transform">
                    <WhatsappIcon class="w-4 h-4" />
                  </span>
                </a>
              )}
            </div>
          </div>
        );
      })}
    </div>

  </div>
</section>

<script>
  document.querySelectorAll<HTMLButtonElement>('.faq-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const item   = btn.closest('.faq-item')!;
      const answer = item.querySelector<HTMLElement>('.faq-answer')!;
      const icon   = btn.querySelector<HTMLElement>('.faq-icon')!;
      const isOpen = !answer.classList.contains('hidden');

      document.querySelectorAll('.faq-answer').forEach(a => a.classList.add('hidden'));
      document.querySelectorAll('.faq-icon').forEach(i => (i as HTMLElement).style.transform = 'rotate(0deg)');
      document.querySelectorAll('.faq-btn').forEach(b => b.setAttribute('aria-expanded', 'false'));

      if (!isOpen) {
        answer.classList.remove('hidden');
        icon.style.transform = 'rotate(180deg)';
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });
</script>
