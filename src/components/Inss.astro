---
import { getSetting } from '../lib/site-content';
import { sanitizeRichText } from '../lib/sanitize';

interface Slide { eyebrow: string; titulo_html: string; paragrafo: string; }
const slides = (await getSetting<Slide[]>('inss_slides')) ?? [];
---

<section id="inss" class="bg-surface py-20 md:py-28 overflow-hidden">
  <div class="max-w-4xl mx-auto px-6 md:px-8 text-center">

    <div id="inss-slider" class="grid touch-pan-y select-none cursor-grab active:cursor-grabbing">
      {slides.map((s, i) => (
        <div class={`inss-slide [grid-area:1/1] transition-opacity duration-700 ease-in-out ${i === 0 ? 'opacity-100' : 'opacity-0 pointer-events-none'}`}>
          <span class="text-secondary font-bold tracking-[0.3em] uppercase text-xs mb-5 block">{s.eyebrow}</span>
          <h2 class="font-headline text-4xl md:text-5xl lg:text-6xl font-bold text-primary leading-[1.05] tracking-tight [text-wrap:balance]" set:html={sanitizeRichText(s.titulo_html)}></h2>
          <p class="mt-6 md:mt-8 text-on-surface-variant leading-relaxed max-w-2xl mx-auto text-base md:text-lg [text-wrap:pretty]">
            {s.paragrafo}
          </p>
        </div>
      ))}
    </div>

    <div class="flex justify-center gap-2 mt-10 md:mt-12" id="inss-dots">
      {slides.map((_, i) => (
        <button
          type="button"
          class={`inss-dot h-2 rounded-full transition-all duration-500 ${i === 0 ? 'bg-secondary w-8' : 'bg-primary/20 w-2 hover:bg-primary/40'}`}
          data-idx={i}
          aria-label={`Slide ${i + 1}`}
        ></button>
      ))}
    </div>

  </div>
</section>

<script>
  const slides = document.querySelectorAll<HTMLElement>('.inss-slide');
  const dots   = document.querySelectorAll<HTMLButtonElement>('.inss-dot');
  let current  = 0;
  let timer: ReturnType<typeof setInterval> | null = null;

  function go(idx: number) {
    if (idx === current) return;
    slides[current].classList.add('opacity-0', 'pointer-events-none');
    slides[current].classList.remove('opacity-100');
    dots[current].classList.remove('bg-secondary', 'w-8');
    dots[current].classList.add('bg-primary/20', 'w-2');

    current = idx;

    slides[current].classList.remove('opacity-0', 'pointer-events-none');
    slides[current].classList.add('opacity-100');
    dots[current].classList.add('bg-secondary', 'w-8');
    dots[current].classList.remove('bg-primary/20', 'w-2');
  }

  function next() {
    go((current + 1) % slides.length);
  }

  function start() {
    if (timer) clearInterval(timer);
    timer = setInterval(next, 6000);
  }

  dots.forEach((d, i) => {
    d.addEventListener('click', () => {
      go(i);
      start();
    });
  });

  // Swipe (mobile e qualquer tela touch)
  const slider = document.getElementById('inss-slider');
  if (slider && slides.length > 1) {
    let startX = 0;
    let startY = 0;
    let tracking = false;
    const THRESHOLD = 40;

    slider.addEventListener('touchstart', (e) => {
      const t = e.touches[0];
      startX = t.clientX;
      startY = t.clientY;
      tracking = true;
    }, { passive: true });

    slider.addEventListener('touchend', (e) => {
      if (!tracking) return;
      tracking = false;
      const t = e.changedTouches[0];
      const dx = t.clientX - startX;
      const dy = t.clientY - startY;
      if (Math.abs(dx) < THRESHOLD || Math.abs(dx) < Math.abs(dy)) return;
      if (dx < 0) {
        go((current + 1) % slides.length);
      } else {
        go((current - 1 + slides.length) % slides.length);
      }
      start();
    }, { passive: true });
  }

  if (slides.length > 1) start();
</script>
