---
import { getSetting, asset } from '../lib/site-content';
import { sanitizeRichText } from '../lib/sanitize';
const TURNSTILE_KEY = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY;
const wa = (await getSetting<{ numero: string; mensagem_default: string }>('whatsapp')) ?? { numero: '5566996752309', mensagem_default: '' };
const card = (await getSetting<{ titulo_html: string }>('contato_card')) ?? { titulo_html: 'Fale com a HB Construtora' };
---

<section id="contato-section" class="relative overflow-hidden py-20 md:py-28 rounded-t-3xl -mt-8 z-10">

  <div class="absolute inset-0 overflow-hidden bg-primary">
    <!-- Mesmo tratamento do hero: no mobile fica só a cor sólida (o fundo é 80%
         coberto pelo overlay); o vídeo roda só no desktop e com preload=none, pra
         não baixar durante o carregamento inicial e disputar banda com o LCP no 4G. -->
    <video
      id="contato-video"
      class="hidden md:block absolute inset-0 w-full h-full object-cover"
      src={asset('/contato/contato-bg.mp4')}
      poster={asset('/contato/contato-bg.webp')}
      autoplay
      muted
      loop
      playsinline
      preload="none"
      aria-hidden="true"
    ></video>
    <div class="hidden md:block absolute inset-0 bg-primary/80"></div>
  </div>

  <div class="relative max-w-4xl mx-auto px-6 md:px-10">

    <div id="contato" class="scroll-mt-24 max-w-2xl mx-auto bg-primary-container/80 backdrop-blur-md rounded-2xl p-8 md:p-10 border border-white/10 shadow-2xl">
      <h3 class="font-headline text-3xl font-bold text-white mb-6 text-center md:uppercase md:whitespace-nowrap" set:html={sanitizeRichText(card.titulo_html)}></h3>
      <input type="hidden" id="wa-numero" value={wa.numero} />

      <form id="lead-form" class="space-y-4" novalidate>
        <!-- Honeypot anti-spam (humanos não veem; bots preenchem) -->
        <div class="absolute -left-[9999px]" aria-hidden="true">
          <label>Não preencha este campo:
            <input type="text" name="website" tabindex="-1" autocomplete="off" />
          </label>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label for="lead-nome" class="block text-xs text-white/50 mb-1.5 uppercase tracking-wide">Nome completo</label>
            <input
              id="lead-nome"
              name="nome"
              type="text"
              required
              autocomplete="name"
              class="w-full bg-white/5 border border-white/15 text-white placeholder-white/25 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-brand-orange transition-colors"
              aria-describedby="erro-nome"
            />
            <p id="erro-nome" class="text-error mt-1.5 text-xs hidden"></p>
          </div>
          <div>
            <label for="lead-telefone" class="block text-xs text-white/50 mb-1.5 uppercase tracking-wide">Telefone</label>
            <input
              id="lead-telefone"
              name="telefone"
              type="tel"
              required
              inputmode="numeric"
              autocomplete="tel"
              placeholder="(00) 00000-0000"
              class="w-full bg-white/5 border border-white/15 text-white placeholder-white/25 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-brand-orange transition-colors"
              aria-describedby="erro-telefone"
            />
            <p id="erro-telefone" class="text-error mt-1.5 text-xs hidden"></p>
          </div>
        </div>

        <div>
          <label for="lead-cidade" class="block text-xs text-white/50 mb-1.5 uppercase tracking-wide">Cidade</label>
          <input
            id="lead-cidade"
            name="cidade"
            type="text"
            autocomplete="address-level2"
            placeholder="Ex: Sinop - MT"
            class="w-full bg-white/5 border border-white/15 text-white placeholder-white/25 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-brand-orange transition-colors"
          />
        </div>

        <div class="relative" id="wrapper-tipo">
          <label id="label-text-tipo" class="block text-xs text-white/50 mb-1.5 uppercase tracking-wide">Qual seu projeto?</label>
          <input type="hidden" name="tipo" id="tipo-value" value="" />
          <button
            type="button"
            id="btn-tipo"
            class="w-full bg-white/5 border border-white/15 text-white/50 rounded-lg px-4 py-3 text-sm text-left flex justify-between items-center focus:outline-none focus:border-brand-orange transition-colors"
            aria-haspopup="listbox"
            aria-expanded="false"
            aria-controls="dropdown-tipo"
            aria-labelledby="label-text-tipo label-tipo"
          >
            <span id="label-tipo">Selecione sua resposta</span>
            <svg class="w-4 h-4 text-white/40 flex-shrink-0 transition-transform duration-200" id="arrow-tipo" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          <ul
            id="dropdown-tipo"
            role="listbox"
            aria-labelledby="label-text-tipo"
            tabindex="-1"
            class="hidden absolute left-0 right-0 top-full mt-1 bg-primary-container/95 backdrop-blur-md border border-white/15 rounded-lg overflow-hidden z-20 shadow-2xl outline-none"
          >
            {['Casa Residencial', 'Prédio Comercial', 'Galpão Comercial', 'Outro'].map(opt => (
              <li
                role="option"
                aria-selected="false"
                tabindex="-1"
                class="opt-tipo w-full text-left px-4 py-3 text-sm text-white/70 hover:bg-white/10 hover:text-white focus:bg-white/10 focus:text-white outline-none cursor-pointer transition-colors"
                data-value={opt}
              >
                {opt}
              </li>
            ))}
          </ul>
          <p id="erro-tipo" class="text-error mt-1.5 text-xs hidden"></p>
        </div>

        <div class="relative" id="wrapper-etapa">
          <label id="label-text-etapa" class="block text-xs text-white/50 mb-1.5 uppercase tracking-wide">Qual a etapa do seu projeto?</label>
          <input type="hidden" name="etapa" id="etapa-value" value="" />
          <button
            type="button"
            id="btn-etapa"
            class="w-full bg-white/5 border border-white/15 text-white/50 rounded-lg px-4 py-3 text-sm text-left flex justify-between items-center focus:outline-none focus:border-brand-orange transition-colors"
            aria-haspopup="listbox"
            aria-expanded="false"
            aria-controls="dropdown-etapa"
            aria-labelledby="label-text-etapa label-etapa"
          >
            <span id="label-etapa">Selecione sua resposta</span>
            <svg class="w-4 h-4 text-white/40 flex-shrink-0 transition-transform duration-200" id="arrow-etapa" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          <ul
            id="dropdown-etapa"
            role="listbox"
            aria-labelledby="label-text-etapa"
            tabindex="-1"
            class="hidden absolute left-0 right-0 top-full mt-1 bg-primary-container/95 backdrop-blur-md border border-white/15 rounded-lg overflow-hidden z-20 shadow-2xl outline-none"
          >
            {['Ainda não tenho terreno', 'Tenho terreno, sem projeto', 'Pronto para começar'].map(opt => (
              <li
                role="option"
                aria-selected="false"
                tabindex="-1"
                class="opt-etapa w-full text-left px-4 py-3 text-sm text-white/70 hover:bg-white/10 hover:text-white focus:bg-white/10 focus:text-white outline-none cursor-pointer transition-colors"
                data-value={opt}
              >
                {opt}
              </li>
            ))}
          </ul>
          <p id="erro-etapa" class="text-error mt-1.5 text-xs hidden"></p>
        </div>

        {TURNSTILE_KEY && (
          <div class="cf-turnstile" data-sitekey={TURNSTILE_KEY} data-theme="dark" data-size="flexible"></div>
        )}

        <button
          type="submit"
          id="lead-submit"
          class="w-full bg-orange-gradient text-white py-4 font-bold uppercase tracking-widest text-sm hover:brightness-110 transition-all rounded-lg mt-2 disabled:opacity-50 disabled:cursor-wait"
        >
          Enviar
        </button>

        <p id="form-status" role="status" aria-live="polite" class="text-center text-sm hidden"></p>
      </form>
    </div>
  </div>
</section>

{TURNSTILE_KEY && (
  <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
)}

<script>
  // ---------- Helpers ----------
  function setError(field: string, msg: string) {
    const el = document.getElementById(`erro-${field}`);
    if (!el) return;
    el.textContent = msg;
    el.classList.toggle('hidden', !msg);
  }

  function clearErrors() {
    ['nome', 'telefone', 'tipo', 'etapa'].forEach(f => setError(f, ''));
  }

  // ---------- Dropdown acessível ----------
  function makeDropdown(btnId: string, dropdownId: string, arrowId: string, labelId: string, inputId: string, optClass: string, fieldName: string) {
    const btn      = document.getElementById(btnId) as HTMLButtonElement;
    const dropdown = document.getElementById(dropdownId) as HTMLElement;
    const arrow    = document.getElementById(arrowId) as HTMLElement;
    const label    = document.getElementById(labelId) as HTMLElement;
    const hidden   = document.getElementById(inputId) as HTMLInputElement;
    const opts     = Array.from(dropdown.querySelectorAll<HTMLElement>('.' + optClass));
    let activeIdx  = -1;

    function open() {
      dropdown.classList.remove('hidden');
      btn.setAttribute('aria-expanded', 'true');
      arrow.style.transform = 'rotate(180deg)';
      activeIdx = opts.findIndex(o => o.getAttribute('aria-selected') === 'true');
      if (activeIdx === -1) activeIdx = 0;
      opts[activeIdx]?.focus();
    }

    function close() {
      dropdown.classList.add('hidden');
      btn.setAttribute('aria-expanded', 'false');
      arrow.style.transform = '';
    }

    function select(opt: HTMLElement) {
      const val = opt.dataset.value || '';
      hidden.value = val;
      label.textContent = val;
      label.classList.replace('text-white/50', 'text-white');
      opts.forEach(o => o.setAttribute('aria-selected', o === opt ? 'true' : 'false'));
      setError(fieldName, '');
      close();
      btn.focus();
    }

    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const isOpen = !dropdown.classList.contains('hidden');
      document.querySelectorAll('[role="listbox"]').forEach(d => d.classList.add('hidden'));
      document.querySelectorAll('[aria-haspopup="listbox"]').forEach(b => b.setAttribute('aria-expanded', 'false'));
      document.querySelectorAll('[id^="arrow-"]').forEach(a => ((a as HTMLElement).style.transform = ''));
      if (!isOpen) open();
    });

    btn.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowDown' || e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        open();
      }
    });

    opts.forEach((opt, i) => {
      opt.addEventListener('click', () => select(opt));
      opt.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowDown') {
          e.preventDefault();
          activeIdx = (i + 1) % opts.length;
          opts[activeIdx].focus();
        } else if (e.key === 'ArrowUp') {
          e.preventDefault();
          activeIdx = (i - 1 + opts.length) % opts.length;
          opts[activeIdx].focus();
        } else if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          select(opt);
        } else if (e.key === 'Escape') {
          e.preventDefault();
          close();
          btn.focus();
        } else if (e.key === 'Tab') {
          close();
        }
      });
    });
  }

  makeDropdown('btn-tipo',  'dropdown-tipo',  'arrow-tipo',  'label-tipo',  'tipo-value',  'opt-tipo',  'tipo');
  makeDropdown('btn-etapa', 'dropdown-etapa', 'arrow-etapa', 'label-etapa', 'etapa-value', 'opt-etapa', 'etapa');

  document.addEventListener('click', () => {
    document.querySelectorAll('[role="listbox"]').forEach(d => d.classList.add('hidden'));
    document.querySelectorAll('[aria-haspopup="listbox"]').forEach(b => b.setAttribute('aria-expanded', 'false'));
    document.querySelectorAll('[id^="arrow-"]').forEach(a => ((a as HTMLElement).style.transform = ''));
  });

  // ---------- Máscara telefone ----------
  const telInput = document.getElementById('lead-telefone') as HTMLInputElement;
  telInput.addEventListener('input', () => {
    const v = telInput.value.replace(/\D/g, '').slice(0, 11);
    let out = '';
    if (v.length === 0)        out = '';
    else if (v.length <= 2)    out = `(${v}`;
    else if (v.length <= 6)    out = `(${v.slice(0, 2)}) ${v.slice(2)}`;
    else if (v.length <= 10)   out = `(${v.slice(0, 2)}) ${v.slice(2, 6)}-${v.slice(6)}`;
    else                       out = `(${v.slice(0, 2)}) ${v.slice(2, 7)}-${v.slice(7)}`;
    telInput.value = out;
  });

  // ---------- Validação ----------
  function validate(nome: string, telefone: string, tipo: string, etapa: string): boolean {
    clearErrors();
    let ok = true;
    const nomeTrim = nome.trim();
    const palavras = nomeTrim.split(/\s+/).filter(Boolean);

    if (nomeTrim.length < 3) {
      setError('nome', 'Nome muito curto.');
      ok = false;
    } else if (!/^[A-Za-zÀ-ÿ' -]+$/.test(nomeTrim)) {
      setError('nome', 'Use apenas letras.');
      ok = false;
    } else if (palavras.length < 2) {
      setError('nome', 'Digite seu nome completo.');
      ok = false;
    }

    const digits = telefone.replace(/\D/g, '');
    if (digits.length < 10 || digits.length > 11) {
      setError('telefone', 'Telefone incompleto. Use (DD) número completo.');
      ok = false;
    }

    if (!tipo) {
      setError('tipo', 'Selecione o tipo de projeto.');
      ok = false;
    }
    if (!etapa) {
      setError('etapa', 'Selecione a etapa do projeto.');
      ok = false;
    }

    return ok;
  }

  // ---------- Submit ----------
  const form        = document.getElementById('lead-form') as HTMLFormElement;
  const tipoVal     = document.getElementById('tipo-value') as HTMLInputElement;
  const etapaVal    = document.getElementById('etapa-value') as HTMLInputElement;
  const submitBtn   = document.getElementById('lead-submit') as HTMLButtonElement;
  const status      = document.getElementById('form-status') as HTMLElement;

  function showStatus(msg: string, kind: 'success' | 'error') {
    status.textContent = msg;
    status.classList.remove('hidden', 'text-error', 'text-success');
    status.classList.add(kind === 'success' ? 'text-success' : 'text-error');
  }

  form.addEventListener('submit', async (e: Event) => {
    e.preventDefault();
    if (submitBtn.disabled) return;

    const data     = new FormData(form);
    const honeypot = (data.get('website') as string) || '';
    if (honeypot) {
      showStatus('Enviado!', 'success');
      return;
    }

    const nome     = (data.get('nome') as string) || '';
    const telefone = (data.get('telefone') as string) || '';
    const cidade   = ((data.get('cidade') as string) || '').trim();
    const tipo     = tipoVal.value;
    const etapa    = etapaVal.value;

    if (!validate(nome, telefone, tipo, etapa)) {
      showStatus('Verifique os campos destacados.', 'error');
      return;
    }

    submitBtn.disabled = true;
    showStatus('Enviando...', 'success');

    const lead = {
      nome: nome.trim(),
      telefone: telefone.trim(),
      cidade: cidade || null,
      tipo,
      etapa,
    };

    const turnstileToken = (form.querySelector('[name="cf-turnstile-response"]') as HTMLInputElement | null)?.value || '';

    let registered = false;
    try {
      const res = await fetch('/api/leads/create', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ ...lead, turnstileToken }),
      });
      registered = res.ok;
      if (!res.ok && res.status !== 429) {
        const data = await res.json().catch(() => ({}));
        console.error('[leads] erro:', res.status, data);
      }
      if (res.status === 429) {
        showStatus('Muitas tentativas. Aguarde 1 minuto.', 'error');
        submitBtn.disabled = false;
        return;
      }
    } catch (err) {
      console.error('[leads] network error:', err);
    }

    if (!registered) {
      showStatus('Não conseguimos registrar agora, mas vamos te direcionar pro WhatsApp.', 'error');
    }

    (window as any).dataLayer = (window as any).dataLayer || [];
    (window as any).dataLayer.push({
      event: 'lead_submit',
      lead_tipo: tipo,
      lead_etapa: etapa,
      lead_cidade: cidade || 'não informada',
    });

    const waNumero = (document.getElementById('wa-numero') as HTMLInputElement)?.value || '5566996752309';
    const msg = `Olá Hemerson! Me chamo *${lead.nome}*, telefone *${lead.telefone}*. Tenho interesse em orçamento para *${tipo}*${cidade ? ` em *${cidade}*` : ''}. Etapa: *${etapa}*.`;
    const waUrl = `https://wa.me/${waNumero}?text=${encodeURIComponent(msg)}`;

    if (registered) {
      showStatus('Lead registrado! Abrindo WhatsApp...', 'success');
      form.reset();
      tipoVal.value = '';
      etapaVal.value = '';
      document.getElementById('label-tipo')!.textContent = 'Selecione sua resposta';
      document.getElementById('label-etapa')!.textContent = 'Selecione sua resposta';
      document.getElementById('label-tipo')!.classList.replace('text-white', 'text-white/50');
      document.getElementById('label-etapa')!.classList.replace('text-white', 'text-white/50');
      if ((window as any).turnstile) (window as any).turnstile.reset();
    }

    const a = document.createElement('a');
    a.href = waUrl;
    a.target = '_blank';
    a.rel = 'noopener noreferrer';
    document.body.appendChild(a);
    a.click();
    a.remove();

    submitBtn.disabled = false;
  });
</script>
