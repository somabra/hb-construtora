---
---

<section id="contato" class="py-24 bg-surface-container-low">
  <div class="max-w-7xl mx-auto px-5 md:px-8">
    <div class="grid md:grid-cols-2 gap-10 md:gap-20">

      <!-- Info -->
      <div>
        <h2 class="font-headline text-4xl font-bold text-primary mb-8">Vamos construir algo incrível juntos?</h2>
        <p class="text-on-surface-variant mb-12">
          Estamos prontos para ouvir sua ideia e transformar em um projeto sólido. Preencha o formulário ou entre em contato pelos nossos canais.
        </p>

        <div class="space-y-8">
          <div class="flex items-start gap-4">
            <span class="material-symbols-outlined text-secondary">phone_iphone</span>
            <div>
              <p class="font-bold text-primary">Telefone / WhatsApp</p>
              <a href="tel:+5566996752309" class="text-on-surface-variant hover:text-secondary transition-colors">
                (66) 99675-2309
              </a>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <span class="material-symbols-outlined text-secondary">location_on</span>
            <div>
              <p class="font-bold text-primary">Endereço</p>
              <p class="text-on-surface-variant">Rua dos Angicos, 1494, Jardim Imperial — Sinop, MT</p>
            </div>
          </div>

          <div class="flex gap-4 pt-2">
            <a
              href="https://instagram.com/hbconstrutoramt"
              target="_blank"
              rel="noopener noreferrer"
              class="w-10 h-10 border border-primary/20 flex items-center justify-center rounded-full hover:bg-secondary hover:text-white transition-all"
              aria-label="Instagram"
            >
              <span class="material-symbols-outlined text-xl">camera_alt</span>
            </a>
            <a
              href="https://wa.me/5566996752309"
              target="_blank"
              rel="noopener noreferrer"
              class="w-10 h-10 border border-primary/20 flex items-center justify-center rounded-full hover:bg-secondary hover:text-white transition-all"
              aria-label="WhatsApp"
            >
              <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
            </a>
          </div>
        </div>
      </div>

      <!-- Formulário -->
      <div class="bg-[#0f1f5c] p-6 md:p-10 rounded-2xl shadow-2xl">
        <form id="lead-form" class="space-y-6">
          <div>
            <label class="block text-sm font-bold text-white mb-2 uppercase tracking-tighter">Nome Completo</label>
            <input
              name="nome"
              type="text"
              required
              placeholder="Seu nome"
              class="w-full bg-white/10 text-white placeholder-white/40 border border-white/20 rounded-xl focus:outline-none focus:border-[#4a90e2] p-4 transition-all"
            />
          </div>
          <div>
            <label class="block text-sm font-bold text-white mb-2 uppercase tracking-tighter">Telefone</label>
            <input
              name="telefone"
              type="tel"
              required
              placeholder="(00) 00000-0000"
              class="w-full bg-white/10 text-white placeholder-white/40 border border-white/20 rounded-xl focus:outline-none focus:border-[#4a90e2] p-4 transition-all"
            />
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-bold text-white mb-2 uppercase tracking-tighter">Cidade</label>
              <select name="cidade" class="w-full bg-white/10 text-white border border-white/20 rounded-xl focus:outline-none focus:border-[#4a90e2] p-4 transition-all">
                <option class="text-black">Sinop e proximidades</option>
                <option class="text-black">Juína e proximidades</option>
                <option class="text-black">Outra cidade</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-bold text-white mb-2 uppercase tracking-tighter">Tipo de Obra</label>
              <select name="tipo" class="w-full bg-white/10 text-white border border-white/20 rounded-xl focus:outline-none focus:border-[#4a90e2] p-4 transition-all">
                <option class="text-black">Casa Residencial</option>
                <option class="text-black">Prédio Comercial</option>
                <option class="text-black">Galpão Comercial</option>
                <option class="text-black">Outro</option>
              </select>
            </div>
          </div>
          <button
            type="submit"
            class="w-full bg-gradient-to-r from-[#f0884a] to-[#d94e18] text-white py-5 font-bold uppercase tracking-widest rounded-xl hover:brightness-110 transition-all"
          >
            Solicitar Orçamento Grátis
          </button>
        </form>
      </div>

    </div>
  </div>
</section>

<script>
  const form = document.getElementById('lead-form') as HTMLFormElement;
  form.addEventListener('submit', (e: Event) => {
    e.preventDefault();
    const data     = new FormData(form);
    const nome     = data.get('nome') as string;
    const telefone = data.get('telefone') as string;
    const cidade   = data.get('cidade') as string;
    const tipo     = data.get('tipo') as string;
    const msg = `Olá Hemerson! Me chamo *${nome}*, telefone *${telefone}*. Tenho interesse em orçamento para *${tipo}* em *${cidade}*.`;
    window.open(`https://wa.me/5566996752309?text=${encodeURIComponent(msg)}`, '_blank');
  });
</script>
