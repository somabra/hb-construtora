---
const cards = [
  {
    icon: 'assignment_ind',
    title: 'Acompanhamento Pessoal',
    desc: 'Gestão direta e próxima em todas as etapas da sua obra, garantindo que nada passe despercebido.',
  },
  {
    icon: 'verified_user',
    title: 'Zero Retrabalho',
    desc: 'Processos rigorosos de qualidade para entregar resultados perfeitos na primeira vez.',
  },
  {
    icon: 'vpn_key',
    title: 'Do Projeto à Chave',
    desc: 'Cuidamos de tudo: da concepção arquitetônica até a limpeza final para sua entrada.',
  },
  {
    icon: 'location_on',
    title: 'Sinop e Região',
    desc: 'Especialistas no mercado local de Mato Grosso, com logística e fornecedores parceiros.',
  },
];
---

<section class="py-12 bg-surface">
  <div class="max-w-7xl mx-auto px-8">

    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-8">
      {cards.map(card => (
        <div class="bg-surface-container-low p-5 md:p-8 border-t-4 border-secondary shadow-md hover:shadow-2xl hover:-translate-y-3 transition-all duration-300">
          <div class="w-10 h-10 md:w-16 md:h-16 bg-[#ffdbcf] rounded-full flex items-center justify-center mb-4">
            <span class="material-symbols-outlined text-secondary text-xl md:text-3xl">{card.icon}</span>
          </div>
          <h3 class="font-headline text-sm md:text-xl font-bold mb-2 md:mb-4 text-primary leading-tight">{card.title}</h3>
          <p class="text-on-surface-variant text-xs md:text-sm leading-relaxed hidden md:block">{card.desc}</p>
        </div>
      ))}
    </div>


  </div>
</section>
