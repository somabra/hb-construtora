---
---

<section id="projetos" class="py-24 bg-[#0f0f0f] rounded-t-[2.5rem] rounded-b-[1rem]">
  <div class="max-w-5xl mx-auto px-8">

    <!-- Título seção -->
    <div class="flex items-center gap-4 mb-14">
      <div class="flex-1 h-px bg-white/10"></div>
      <h2 class="font-headline text-white/80 text-lg uppercase tracking-[0.4em] font-bold whitespace-nowrap">Projetos</h2>
      <div class="flex-1 h-px bg-white/10"></div>
    </div>

    <!-- Card Mauro Sandaniel -->
    <div class="max-w-sm mx-auto md:mx-0">
      <div class="bg-[#2a2a2a] rounded-2xl overflow-hidden border border-white/10 shadow-2xl">

        <!-- Logo no lugar da foto -->
        <div class="relative aspect-video overflow-hidden">
          <img src="/mauro-logo.png" alt="Studio Mauro Sandaniel" class="w-full h-full object-cover" />
          <span class="absolute top-3 right-3 bg-black text-white/70 text-[10px] font-light uppercase tracking-widest px-3 py-1 rounded">
            Entregue
          </span>
        </div>

        <!-- Info do card -->
        <div class="p-6">
          <h3 class="text-white font-bold text-lg mb-1">Salão Mauro Sandaniel</h3>
          <p class="text-white/40 text-sm mb-5">Reforma completa de fachada — Sinop, MT</p>

          <button
            id="btn-mauro"
            class="flex items-center gap-2 border border-white/20 text-white text-sm font-medium px-5 py-3 rounded-xl hover:bg-white hover:text-black transition-all duration-300 w-full justify-center"
          >
            <span id="btn-mauro-label">Veja como ficou</span>
            <svg id="btn-mauro-arrow" class="w-4 h-4 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </button>
        </div>
      </div>
    </div>

    <!-- Conteúdo expansível -->
    <div id="mauro-body" class="overflow-hidden transition-all duration-500 ease-in-out max-h-0">
      <div class="pt-12">

        <!-- Fotos extras -->
        <div class="grid grid-cols-2 gap-4 mt-6">
          <div class="rounded-2xl overflow-hidden aspect-video">
            <img src="/mauro-fachada.png" alt="Fachada" class="w-full h-full object-cover hover:scale-105 transition-transform duration-700" />
          </div>
          <div class="rounded-2xl overflow-hidden aspect-video">
            <img src="/mauro-fachada2.jpg" alt="Fachada Mauro Sandaniel Studio" class="w-full h-full object-cover hover:scale-105 transition-transform duration-700" />
          </div>
        </div>

        <!-- Entrega da chave -->
        <div class="mt-8 text-center">
          <p class="text-white text-base uppercase tracking-[0.35em] font-bold mb-4">Entrega da Chave</p>
          <div class="rounded-2xl overflow-hidden max-w-lg mx-auto aspect-video">
            <img src="/mauro-entrega.jpg" alt="Entrega da chave — HB Construtora" class="w-full h-full object-cover hover:scale-105 transition-transform duration-700" />
          </div>
        </div>

        <!-- Antes & Depois -->
        <div class="md:max-w-[80%] mx-auto mt-10">
        <p class="text-white text-base uppercase tracking-[0.35em] font-bold text-center mb-6">Antes & Depois</p>
        <div
          id="slider-wrap"
          class="relative w-full rounded-2xl overflow-hidden select-none cursor-ew-resize shadow-2xl"
          style="aspect-ratio: 4/3;"
        >
          <img src="/mauro-depois.png" alt="Depois" class="absolute inset-0 w-full h-full object-cover" draggable="false" />
          <div id="antes-clip" class="absolute inset-0 overflow-hidden" style="width: 50%;">
            <img id="antes-img" src="/mauro-antes.png" alt="Antes" class="absolute inset-0 h-full object-cover" style="width: 100vw; max-width: none; transform: scale(1.20); transform-origin: center center;" draggable="false" />
          </div>
          <span class="absolute top-4 left-4 bg-black/60 text-white text-xs font-bold uppercase tracking-widest px-3 py-1 rounded-full pointer-events-none">Antes</span>
          <span class="absolute top-4 right-4 bg-black/60 text-white text-xs font-bold uppercase tracking-widest px-3 py-1 rounded-full pointer-events-none">Depois</span>
          <div id="divider" class="absolute top-0 bottom-0 w-[2px] bg-white shadow-[0_0_12px_rgba(255,255,255,0.8)]" style="left:50%;transform:translateX(-50%);">
            <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-10 h-10 bg-white rounded-full shadow-xl flex items-center justify-center pointer-events-none">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#333" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#333" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-left:-8px"><polyline points="9 18 15 12 9 6"></polyline></svg>
            </div>
          </div>
        </div>
        </div>

        <!-- Vídeo -->
        <div class="mt-10">
          <p class="text-white text-base uppercase tracking-[0.35em] font-bold text-center mb-6">Vídeo do Projeto</p>
          <div class="w-full rounded-2xl overflow-hidden bg-white/5 border border-white/10 flex items-center justify-center" style="aspect-ratio:16/9;">
            <div class="text-center text-white/30">
              <svg class="w-14 h-14 mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              <p class="text-sm font-medium">Vídeo em breve</p>
            </div>
          </div>
        </div>

      </div>
    </div>

  </div>
</section>

<script>
  const btn   = document.getElementById('btn-mauro')!;
  const body  = document.getElementById('mauro-body')!;
  const arrow = document.getElementById('btn-mauro-arrow')!;
  const label = document.getElementById('btn-mauro-label')!;
  let open    = false;

  btn.addEventListener('click', () => {
    open = !open;
    if (open) {
      body.style.maxHeight = body.scrollHeight + 2000 + 'px';
      arrow.style.transform = 'rotate(180deg)';
      label.textContent = 'Recolher';
      setTimeout(() => {
        document.getElementById('projetos')!.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }, 100);
    } else {
      body.style.maxHeight = '0';
      arrow.style.transform = 'rotate(0deg)';
      label.textContent = 'Veja como ficou';
    }
  });

  // Slider
  const wrap     = document.getElementById('slider-wrap')!;
  const clip     = document.getElementById('antes-clip')!;
  const divider  = document.getElementById('divider')!;
  const antesImg = document.getElementById('antes-img') as HTMLImageElement;
  let dragging   = false;

  function syncW() { antesImg.style.width = wrap.offsetWidth + 'px'; }
  syncW();
  window.addEventListener('resize', syncW);

  function setPos(x: number) {
    const r = wrap.getBoundingClientRect();
    let p = Math.max(0.02, Math.min(0.98, (x - r.left) / r.width));
    clip.style.width = `${p * 100}%`;
    divider.style.left = `${p * 100}%`;
  }

  wrap.addEventListener('mousedown',  e => { dragging = true; setPos(e.clientX); });
  wrap.addEventListener('touchstart', e => { dragging = true; setPos(e.touches[0].clientX); }, { passive: true });
  window.addEventListener('mousemove',  e => { if (dragging) setPos(e.clientX); });
  window.addEventListener('touchmove',  e => { if (dragging) setPos(e.touches[0].clientX); }, { passive: true });
  window.addEventListener('mouseup',  () => { dragging = false; });
  window.addEventListener('touchend', () => { dragging = false; });
</script>
